>>>malloy
import './real_estate.malloy'
>>>markdown
# Số lượng căn hộ

Số căn hộ được đăng bán của TP HCM nhiều hơn của Hà Nội
>>>malloy
run: real_estate -> {
    group_by: city.name
    aggregate: property_count, average_price, average_price_1m2
}
>>>malloy

run: real_estate -> {
    group_by: city.name, d_name is district.name
    aggregate: property_count, average_price, average_price_1m2
    order_by: name, average_price_1m2 desc
    -- limit: 100
}
>>>malloy

