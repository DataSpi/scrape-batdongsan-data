## Giá trung bình của từng dự án
>>>malloy

run: real_estate -> {
  group_by:  `thành phố` is cityCode
  nest:
    `giá trung bình` is {
      group_by: `tên_quận`
      aggregate: `giá_tb`
      nest: `tổng quan` is general_info + { group_by: `tên_dự_án` order_by: `giá_tb` desc }
      order_by: `giá_tb` desc
    }
  limit: 1000
}
>>>markdown
# Bedrooms
>>>malloy
# dashboard
run: real_estate -> {
  where: bedrooms is not null and bedrooms != '58'
  group_by:
    cityCode
  nest: 
    # bar_chart
    `giá TB` is {
      group_by: bedrooms
      aggregate: `giá_tb`
      order_by: `bedrooms` desc
    }
    # bar_chart
    `số lượng` is {
      group_by: bedrooms
      aggregate: `số lượng` is `số_bài_đăng`
      order_by: `bedrooms` desc
    }
    # bar_chart
    `giá TB 1m2` is {
      group_by: bedrooms
      aggregate: `giá_1m2`
      order_by: `bedrooms` desc
    }
  order_by:
    cityCode desc,
  limit: 100
}
>>>markdown
