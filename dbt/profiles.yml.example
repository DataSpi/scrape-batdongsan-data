# Copy this file to dbt/profiles.yml (gitignored) and adjust if needed.
# Reuses the same service account file already used by src/utils/gcp_conn.py.
batdongsan:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: service-account
      project: your-gcp-project-id
      dataset: re_silver # fallback only; every model sets its own +schema
      location: asia-southeast1
      # dbt resolves relative paths against the current working directory at
      # invocation time (not against this file's location), which differs
      # between `python -m src.orchestrator.run_pipeline` (repo root) and
      # running `dbt` directly from dbt/ -- use an absolute path to avoid that.
      keyfile: /absolute/path/to/scrape-batdongsan-data/gcp_service_account.json
      threads: 4
