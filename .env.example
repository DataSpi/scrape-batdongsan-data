# Copy to .env (gitignored) and fill in real values.

# --- Legacy Postgres/Supabase (Malloy semantic layer only — pipeline chính
# dùng BigQuery qua gcp_service_account.json, không dùng các biến này) ---
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# --- Geocoding (src/_geocode/geocode_locations.py, manual lineage rebuild only) ---
GOOGLE_MAPS_API_KEY=

# --- BigQuery, CI only ---
# Local dev/Docker: đặt gcp_service_account.json ở repo root, không cần biến này
# (xem src/utils/gcp_conn.py). GitHub Actions: base64-decode service account key
# vào biến này thay vì mount file.
GCP_CREDENTIALS_JSON=
